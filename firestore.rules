rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "ripptoprivat@gmail.com";
    }

    // Status Document
    match /settings/status {
      // Publicly readable so all visitors can see the status
      allow read: if true;
      // Only admin can update the status
      allow write: if isAdmin();
    }

    // Found Items Collection
    match /foundItems/{itemId} {
      // Publicly readable so all visitors can see found items
      allow read: if true;
      // Only admin can manage found items
      allow write: if isAdmin();
    }
  }
}
